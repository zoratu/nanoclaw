# NanoClaw Managed Hosting Container
# Runs the NanoClaw orchestrator process for a single tenant.
# Polls SQS for inbound messages, processes via Claude Agent SDK, replies via Twilio.

# --- Build stage ---
FROM node:22-slim AS build

WORKDIR /app

COPY package*.json ./
RUN npm install --ignore-scripts && npm rebuild better-sqlite3

COPY tsconfig.json ./
COPY src/ ./src/

RUN npx tsc

# --- Production stage ---
FROM node:22-slim

# Install minimal system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install claude-code globally (used by container-runner for agent invocation)
RUN npm install -g @anthropic-ai/claude-code

WORKDIR /app

# Copy package files and install production-only deps
COPY package*.json ./
RUN npm install --omit=dev --ignore-scripts && npm rebuild better-sqlite3

# Copy compiled JS from build stage
COPY --from=build /app/dist ./dist

# Create data directories (will be overlaid by EFS mount at /data)
RUN mkdir -p /data/store /data/groups /data/config

# Non-root user
RUN chown -R node:node /app /data
USER node

# Health check
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
    CMD node -e "process.exit(0)"

# Environment variables (overridden at runtime by ECS task)
ENV NODE_ENV=production
ENV ASSISTANT_NAME=Ace
ENV STORE_DIR=/data/store
ENV GROUPS_DIR=/data/groups
ENV DATA_DIR=/data

# Start the orchestrator
CMD ["node", "dist/index.js"]
